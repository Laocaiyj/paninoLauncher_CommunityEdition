cabal-version: 3.0
name: panino-core
version: 0.1.0.0
synopsis: Core process for Panino Launcher
description: Minimal P0 core executable for Panino Launcher.
license: Apache-2.0
author: Panino Launcher Contributors
maintainer: dev@panino.local
category: Game
build-type: Simple

