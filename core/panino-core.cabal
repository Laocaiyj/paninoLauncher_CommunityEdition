  build-depends:
    aeson >= 2.2 && < 2.3,
    async >= 2.2 && < 2.3,
    base >= 4.18 && < 5,
    bytestring >= 0.11 && < 0.13,
    containers >= 0.6 && < 0.8,
    cryptohash-sha1 >= 0.11 && < 0.12,
    directory >= 1.3 && < 1.4,
    filepath >= 1.4 && < 1.6,
    http-types >= 0.12 && < 0.13,
    http-client >= 0.7 && < 0.8,
    http-client-tls >= 0.3 && < 0.4,
    network >= 3.1 && < 3.3,
    process >= 1.6 && < 1.7,
    stm >= 2.5 && < 2.6,
    text >= 2.0 && < 2.2,
    time >= 1.12 && < 1.15,
    unix >= 2.7 && < 2.9,
    wai >= 3.2 && < 3.3,
    warp >= 3.3 && < 3.5

executable panino-core
  import: common-options
  ghc-options:
    -rtsopts
  hs-source-dirs: app
  main-is: Main.hs
  other-modules:
    Paths_panino_core
  autogen-modules:
    Paths_panino_core
  build-depends:
    aeson >= 2.2 && < 2.3,
    base >= 4.18 && < 5,
    bytestring >= 0.11 && < 0.13,
    text >= 2.0 && < 2.2,
    panino-core

test-suite panino-core-test
  import: common-options
  type: exitcode-stdio-1.0
  hs-source-dirs: test
  main-is: Main.hs
  build-depends:
    aeson >= 2.2 && < 2.3,
    base >= 4.18 && < 5,
    bytestring >= 0.11 && < 0.13,
    containers >= 0.6 && < 0.8,
    directory >= 1.3 && < 1.4,
    filepath >= 1.4 && < 1.6,
    http-types >= 0.12 && < 0.13,
    process >= 1.6 && < 1.7,
    QuickCheck >= 2.14 && < 2.16,
    stm >= 2.5 && < 2.6,
    text >= 2.0 && < 2.2,
    time >= 1.12 && < 1.13,
    unix >= 2.7 && < 2.9,
    wai >= 3.2 && < 3.3,
    warp >= 3.3 && < 3.5,
    panino-core
